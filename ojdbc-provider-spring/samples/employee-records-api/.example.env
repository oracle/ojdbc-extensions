# Example environment for Employee Records API
# Copy to ".env" and fill real values. .env is git-ignored.
# Load with: set -a; source .env; set +a    (bash/zsh)

# Tenant ID of the Azure App Registrations for an Oracle Database instance and
# this Spring application.
HRAPP_TENANT_ID='xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx'

# Application ID URI of a registered application for an Oracle Database instance
DB_APP_ID_URI='https://example.onmicrosoft.com/xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx'

# OpenID Connect issuer used by the Resource Server (JWT validation)
# Purpose: Validate incoming tokens (iss claim) and discover JWKS via OIDC metadata.
# Either:
#   https://login.microsoftonline.com/$HRAPP_TENANT_ID/v2.0
# Or:
#   https://sts.windows.net/$HRAPP_TENANT_ID/
JWT_ISSUER_URI="https://login.microsoftonline.com/$HRAPP_TENANT_ID/v2.0"

# Oracle JDBC (TCPS + Azure Service Principal token)
ORACLE_JDBC_URL="jdbc:oracle:thin:@(DESCRIPTION=(ADDRESS=(PROTOCOL=tcps)(HOST=<db-host>)(PORT=<db-port>))(SECURITY=(TOKEN_AUTH=AZURE_SERVICE_PRINCIPAL)(AZURE_DB_APP_ID_URI=$DB_APP_ID_URI)(TENANT_ID=$HRAPP_TENANT_ID))(CONNECT_DATA=(SERVICE_NAME=<db-service-name>)))"

# Oracle wallet / trust store (SSO wallet .sso file)
ORACLE_WALLET_TRUSTSTORE='/path/to/cwallet.sso'

# HR App (both JDBC provider client-id and Spring OAuth2 client-id)
HRAPP_CLIENT_ID='<azure-app-client-id>'
HRAPP_CLIENT_SECRET='<azure-app-client-secret>'   # SECRET

# OAuth 2.0 endpoints and scope for client credentials flow
# Purpose: Obtain access tokens for the HR App (client_credentials).
HRAPP_SCOPE="$DB_APP_ID_URI/.default"
HRAPP_TOKEN_URI="https://login.microsoftonline.com/$HRAPP_TENANT_ID/oauth2/v2.0/token"
HRAPP_AUTH_URI="https://login.microsoftonline.com/$HRAPP_TENANT_ID/oauth2/v2.0/authorize"

# Authorization Code + PKCE (delegated) variables
# Purpose: Acquire delegated tokens (user context) using PKCE.
HRAPP_DELEGATED_SCOPE='api://<client-id-or-app-id-uri>/access_as_user'
CODE_VERIFIER='<random-high-entropy-string>'
CODE_CHALLENGE='<S256-hash-of-verifier>'
REDIRECT_URI='http://localhost:3000'
